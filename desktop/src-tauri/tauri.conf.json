{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ObSink",
  "version": "0.1.0",
  "identifier": "com.obsink.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ObSink",
        "label": "main",
        "width": 1240,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
